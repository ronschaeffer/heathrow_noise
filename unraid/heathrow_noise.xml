<?xml version="1.0"?>
<Container version="2">
  <Name>heathrow_noise</Name>
  <Repository>ghcr.io/ronschaeffer/heathrow_noise:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/ronschaeffer/heathrow_noise</Project>
  <Overview>Heathrow runway alternation tracker — publishes noise impact sensors to Home Assistant via MQTT.</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:47480]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/ronschaeffer/heathrow_noise/main/assets/icon.png</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Heathrow runway alternation tracker.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>47480</HostPort>
        <ContainerPort>47480</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/heathrow_noise/config</HostDir>
      <ContainerDir>/app/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>INFO</Value>
      <Name>HEATHROW_NOISE__LOGGING__LEVEL</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>http://server:47480</Value>
      <Name>HEATHROW_NOISE__WEB__EXTERNAL_URL</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="47480" Default="47480" Mode="tcp" Description="Web UI and API port" Type="Port" Display="always" Required="true" Mask="false">47480</Config>
  <Config Name="Config Dir" Target="/app/config" Default="/mnt/user/appdata/heathrow_noise/config" Mode="rw" Description="Config directory — copy config/config.yaml here and customise" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/heathrow_noise/config</Config>
  <Config Name="External URL" Target="HEATHROW_NOISE__WEB__EXTERNAL_URL" Default="http://server:47480" Description="External URL for web UI links" Type="Variable" Display="always" Required="false" Mask="false">http://server:47480</Config>
</Container>
